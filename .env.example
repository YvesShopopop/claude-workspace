# Configuration Zendesk API
# Subdomain Zendesk (sans .zendesk.com)
ZENDESK_SUBDOMAIN=xxx

# Email Zendesk
ZENDESK_EMAIL=xxx

# Token API Zendesk
# Généré dans: Admin > Channels > API
ZENDESK_API_TOKEN=xxx

# IDs de tickets exemple pour identifier le pattern destinataire (séparés par des virgules)
# Utilisés avec : python zendesk_export.py --discover
ZENDESK_EXAMPLE_IDS=123456,789012,345678

# Filtre pour les tickets destinataires (renseigné après avoir lancé --discover)
# Critères séparés par un espace (= AND). Exemples :
#   tags:destinataire
#   group_id:12345
#   ticket_form_id:67890
#   group_id:12345 ticket_form_id:67890
ZENDESK_DESTINATAIRE_FILTER=
